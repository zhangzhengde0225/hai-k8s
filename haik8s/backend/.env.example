# HAI-K8S Backend Configuration
# Copy this file to .env and fill in the values

# JWT
JWT_SECRET_KEY=change-me-in-production

# Default Admin User (created on first startup)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_ADMIN_EMAIL=admin@haik8s.local

# IHEP SSO
IHEP_SSO_CLIENT_ID=your-client-id
IHEP_SSO_CLIENT_SECRET=your-client-secret
IHEP_SSO_AUTHORIZE_URL=https://login.ihep.ac.cn/oauth2/authorize
IHEP_SSO_TOKEN_URL=https://login.ihep.ac.cn/oauth2/token
IHEP_SSO_CALLBACK_URL=http://localhost:42900/api/auth/umt/callback
FRONTEND_CALLBACK_URL=http://localhost:42901/auth/callback

# HepAI
HEPAI_SUBAPP_ADMIN_KEY=your-hepai-subapp-admin-key
## Note: Please contact ai.ihep.ac.cn to obtain the HEPAI_SUBAPP_ADMIN_KEY

# Database
# DATABASE_URL=  # Default: sqlite:///./haik8s.db

# K8s
# KUBECONFIG_PATH=  # Default: REPO_ROOT/.kube/config

# Pod defaults
# DEFAULT_ROOT_PASSWORD=haik8s123
# MACVLAN_NETWORK_NAME=macvlan-conf-same-subnet
# MACVLAN_GATEWAY=10.5.6.1
# MACVLAN_SUBNET=10.5.6.0/24
