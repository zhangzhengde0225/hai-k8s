# HAI-K8S Backend Configuration
# Copy this file to .env and fill in the values

# JWT Secret Key - IMPORTANT: Change this in production!
JWT_SECRET_KEY=change-me-in-production
# JWT Token expiration time in minutes (default: 10080 = 7 days)
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Default Admin User (created automatically on first startup)
# You can customize these values before first run
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_ADMIN_EMAIL=admin@haik8s.local

# IHEP SSO Configuration
IHEP_SSO_CLIENT_ID=your-client-id
IHEP_SSO_CLIENT_SECRET=your-client-secret
IHEP_SSO_AUTHORIZE_URL=https://login.ihep.ac.cn/oauth2/authorize
IHEP_SSO_TOKEN_URL=https://login.ihep.ac.cn/oauth2/token

# Callback URLs
# Development
IHEP_SSO_CALLBACK_URL=http://localhost:42900/api/auth/umt/callback
FRONTEND_CALLBACK_URL=http://localhost:42901/auth/callback
# Production (uncomment and modify for production)
# IHEP_SSO_CALLBACK_URL=https://k8s-ai.ihep.ac.cn/api/auth/umt/callback
# FRONTEND_CALLBACK_URL=https://k8s-ai.ihep.ac.cn/auth/callback

# Database
# Leave empty to use default SQLite database: sqlite:///backend/db/haik8s.db
# DATABASE_URL=

# K8s Configuration
# Leave empty to use default: REPO_ROOT/.kube/config
# KUBECONFIG_PATH=

# CORS Origins (comma-separated list)
# Leave empty to use defaults: localhost:42901, 127.0.0.1:42901, k8s-ai.ihep.ac.cn
# CORS_ORIGINS=http://localhost:42901,https://k8s-ai.ihep.ac.cn
